  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Realized P&L",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(realized_pnl), 0) AS \"Total P&L\" FROM trades WHERE realized_pnl IS NOT NULL",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green",  "value": 0.6 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Win Rate",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN COUNT(*) FILTER (WHERE realized_pnl IS NOT NULL) = 0 THEN 0 ELSE COUNT(*) FILTER (WHERE realized_pnl > 0)::FLOAT / COUNT(*) FILTER (WHERE realized_pnl IS NOT NULL) END AS \"Win Rate\" FROM trades",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Total Trades",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Total Trades\" FROM trades",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Open Unrealized P&L",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(unrealized_pnl), 0) AS \"Unrealized P&L\" FROM positions",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Cumulative P&L Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date AS \"time\", SUM(total_pnl) OVER (ORDER BY date ROWS UNBOUNDED PRECEDING) AS \"Cumulative P&L\" FROM daily_pnl ORDER BY date",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Daily P&L",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date AS \"time\", realized_pnl AS \"Realized\", unrealized_pnl AS \"Unrealized\", total_pnl AS \"Total\" FROM daily_pnl ORDER BY date",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "title": "P&L by Asset Class",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT i.asset_class AS \"Asset Class\", COALESCE(SUM(t.realized_pnl), 0) AS \"P&L\" FROM trades t JOIN instruments i ON t.instrument_id = i.id GROUP BY i.asset_class ORDER BY 2 DESC",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "unrealized_pnl" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_cost" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          },
          {
            "matcher": { "id": "byName", "options": "current_price" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 21 },
      "id": 8,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "unrealized_pnl" }]
      },
      "title": "Current Positions",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT i.symbol, i.asset_class, i.sector, p.quantity, p.avg_cost, p.current_price, p.unrealized_pnl, p.last_updated FROM positions p JOIN instruments i ON p.instrument_id = i.id ORDER BY p.unrealized_pnl DESC NULLS LAST",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "title": "Allocation by Asset Class (Market Value)",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT i.asset_class AS \"Asset Class\", SUM(p.quantity * p.current_price) AS \"Market Value\" FROM positions p JOIN instruments i ON p.instrument_id = i.id GROUP BY i.asset_class ORDER BY 2 DESC",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "TradingDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "title": "P&L by Strategy",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TradingDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(strategy_tag, 'Untagged') AS \"Strategy\", COALESCE(SUM(realized_pnl), 0) AS \"P&L\" FROM trades GROUP BY COALESCE(strategy_tag, 'Untagged') ORDER BY 2 DESC",
          "refId": "A"
        }
      ]
    }
  ],
